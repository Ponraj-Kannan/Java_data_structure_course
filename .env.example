# ── Zoho OAuth 2.0 ────────────────────────────────────────────────────────────
# Client ID is also exposed to the frontend via VITE_ prefix (safe — it's public)
VITE_ZOHO_CLIENT_ID=your_zoho_client_id_here

# Zoho accounts domain — change to https://accounts.zoho.in for India DC,
# https://accounts.zoho.eu for EU, https://accounts.zoho.com.au for AU, etc.
VITE_ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com

# Server-side only — NEVER commit to git, NEVER expose to the browser
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
